{
  "name": "winey",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:js && npm run build:css && npm run build:vendor",
    "build:js": "babel ./public/app.js --out-file ./public/app.legacy.js",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "build:vendor": "node ./scripts/copy-vendor.js",
    "dev": "node --env-file-if-exists=/Users/larrybernstein/.env.keys --watch ./server.js",
    "start": "node --env-file-if-exists=/Users/larrybernstein/.env.keys ./server.js",
    "test": "node --test"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "core-js": "^3.49.0",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "promise-polyfill": "^8.3.0",
    "regenerator-runtime": "^0.14.1",
    "whatwg-fetch": "^3.6.20"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@tailwindcss/cli": "^4.1.17",
    "tailwindcss": "^4.1.17"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
